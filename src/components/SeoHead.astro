---
import { SITE } from '../config/site';
import { normalizePath, socialCardPath, toAbsoluteUrl } from '../utils/seo';

interface Props {
  title?: string;
  description?: string;
  pathname?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  updatedTime?: string;
  tags?: string[];
}

const {
  title,
  description,
  pathname = Astro.url.pathname,
  image,
  type = 'website',
  publishedTime,
  updatedTime,
  tags = [],
} = Astro.props;

const resolvedTitle = title ?? SITE.title;
const resolvedDescription = description ?? SITE.description;
const canonicalPath = normalizePath(pathname);
const canonicalUrl = toAbsoluteUrl(canonicalPath);
const imagePath = image ?? socialCardPath(canonicalPath);
const socialImageUrl = imagePath.startsWith('http')
  ? imagePath
  : toAbsoluteUrl(imagePath);
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<title>{resolvedTitle}</title>
<meta name="description" content={resolvedDescription} />
<meta name="robots" content="index,follow" />
<link rel="canonical" href={canonicalUrl} />

<meta property="og:type" content={type} />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:title" content={resolvedTitle} />
<meta property="og:description" content={resolvedDescription} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:locale" content="en_US" />
<meta property="og:image" content={socialImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />

{publishedTime && <meta property="article:published_time" content={publishedTime} />}
{updatedTime && <meta property="article:modified_time" content={updatedTime} />}
{tags.map((tag) => <meta property="article:tag" content={tag} />)}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={resolvedTitle} />
<meta name="twitter:description" content={resolvedDescription} />
<meta name="twitter:image" content={socialImageUrl} />
