---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate, sortByNewest } from '../../utils/content';

const entries = sortByNewest(
  await getCollection('research', ({ data }) => {
    return !data.draft;
  }),
);
---

<BaseLayout
  title="research | praxis"
  description="research notes on world models, inference systems, and applied optimization workflows."
  pathname={Astro.url.pathname}
>
  <section class="mb-8 max-w-3xl">
    <p class="font-mono text-[0.72rem] uppercase tracking-[0.14em] text-muted">research</p>
    <h1 class="mt-2 text-3xl font-semibold tracking-tight text-text sm:text-4xl">research</h1>
  </section>

  <div class="max-w-3xl border-y border-border">
    {entries.map((entry) => (
      <article class="border-b border-border py-4 last:border-b-0">
        <a class="group block" href={`/research/${entry.slug}/`}>
          <h2 class="text-lg font-semibold tracking-tight text-text group-hover:text-white">
            {entry.data.title}
          </h2>
          <p class="mt-1 text-xs uppercase tracking-[0.08em] text-muted">
            {formatDate(entry.data.pubDate)}
          </p>
        </a>
      </article>
    ))}
  </div>
</BaseLayout>
