---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 | Praxis" description="Page not found." pathname="/404">
  <section class="mx-auto max-w-reading border border-border bg-[#060606] p-8 text-center sm:p-10">
    <p class="font-mono text-[0.72rem] uppercase tracking-[0.12em] text-muted">Error 404</p>
    <h1 class="mt-3 text-3xl font-semibold text-text">Archive page not found</h1>
    <p class="mt-4 text-sm leading-relaxed text-muted">
      The referenced note may have moved as the notebook evolves.
    </p>
    <a class="mt-6 inline-block border border-border px-4 py-2 text-xs uppercase tracking-[0.1em] text-text hover:border-[#3b3b3b]" href="/">
      Return Home
    </a>
  </section>
</BaseLayout>
