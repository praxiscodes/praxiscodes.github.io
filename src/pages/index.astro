---
import { SITE } from '../config/site';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title={SITE.title} description={SITE.description} pathname={Astro.url.pathname}>
  <section class="max-w-reading border border-border bg-[#060606] p-7 sm:p-9">
    <p class="font-mono text-[0.72rem] uppercase tracking-[0.14em] text-muted">Home</p>
    <h1 class="mt-3 text-3xl font-semibold tracking-tight text-text sm:text-4xl">
      praxis, understanding intelligence by building it
    </h1>
  </section>
</BaseLayout>
